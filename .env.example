PINECONE_API_KEY=
COHERE_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
# Required: generate a strong random value, e.g. python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
PERSISTENCE_ENABLED=true
SESSION_HISTORY_TTL_SECONDS=3600
REDIS_URL=
RELEVANCE_SCORE_THRESHOLD=0.55
MAX_CONTENT_LENGTH_BYTES=10489856
MAX_CHAT_MESSAGE_LENGTH=4000
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=60
CHAT_RATE_LIMIT=20
CHAT_RATE_WINDOW_SECONDS=60
DOCUMENT_UPLOAD_RATE_LIMIT=5
DOCUMENT_UPLOAD_RATE_WINDOW_SECONDS=3600
CONTENT_GENERATION_RATE_LIMIT=20
CONTENT_GENERATION_RATE_WINDOW_SECONDS=60
# Set to true only behind HTTPS in production
SECURE_COOKIES=false
# Set to true only for local development
FLASK_DEBUG=false
# Number of gunicorn workers. If REDIS_URL is not set, deploy.py will override this to 1.
GUNICORN_WORKERS=1
